# Database
DATABASE_URL=postgresql://knuckles:knuckles@localhost:5432/knuckles

# App
DEBUG=false
KNUCKLES_BASE_URL=http://localhost:5001
FRONTEND_BASE_URL=http://localhost:3000

# JWT (RS256)
# Base64-encoded PEM-encoded private key (PKCS#8). Generate with:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   base64 -i private.pem
KNUCKLES_JWT_PRIVATE_KEY=
# Stable identifier published on the JWKS. Rotate by issuing a new kid.
KNUCKLES_JWT_KEY_ID=knuckles-2026-04
# Access token lifetime in seconds (default: 3600 = 1h)
KNUCKLES_ACCESS_TOKEN_TTL_SECONDS=3600
# Refresh token lifetime in seconds (default: 2592000 = 30d)
KNUCKLES_REFRESH_TOKEN_TTL_SECONDS=2592000

# Ceremony-state JWTs (short-lived, HS256) — OAuth and passkey state
KNUCKLES_STATE_SECRET=

# Magic link
MAGIC_LINK_TTL_SECONDS=900

# Resend (magic-link delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Apple OAuth
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=

# WebAuthn
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Knuckles
WEBAUTHN_ORIGIN=http://localhost:3000
